// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  prenom      String
  nom         String
  email       String   @unique
  password    String
  phoneNumber String?
  aboutMe     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("users")
}

model Restaurant {
  id          String              @id @default(cuid())
  nom         String
  imageUrls   String              // JSON array of URL strings
  adresse     String
  distinction Int                 // 1, 2 or 3 (étoiles Michelin)
  latitude    Float?
  longitude   Float?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  horaires    RestaurantHoraire[]

  @@map("restaurants")
}

model RestaurantHoraire {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  jour         String // LUNDI | MARDI | MERCREDI | JEUDI | VENDREDI | SAMEDI | DIMANCHE
  creneaux     String     // JSON array: [{ouverture: "12:00", fermeture: "14:30"}, ...]

  @@unique([restaurantId, jour])
  @@map("restaurant_horaires")
}
