// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                   @id @default(cuid())
  prenom              String
  nom                 String
  email               String                   @unique
  password            String
  phoneNumber         String?
  aboutMe             String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  preference          UserPreference?
  favorites           UserDishFavorite[]
  restaurantFavorites UserRestaurantFavorite[]
  hotelFavorites      UserHotelFavorite[]

  @@map("users")
}

model UserPreference {
  userId              String   @id
  veganOnly           Boolean  @default(false)
  excludedIngredients String   @default("[]")
  allergens           String   @default("[]")
  excludedTags        String   @default("[]")
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model UserDishFavorite {
  id                String   @id @default(cuid())
  userId            String
  dishId            String
  restaurantId      String?
  dishTitle         String
  dishCaption       String
  dishImage         String
  dishCuisine       String
  restaurantName    String
  restaurantAddress String
  restaurantHours   String
  restaurantPhone   String?
  expiresAt         DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dishId])
  @@map("user_dish_favorites")
}

model UserRestaurantFavorite {
  id                String     @id @default(cuid())
  userId            String
  restaurantId      String
  restaurantName    String
  restaurantImage   String?
  restaurantAddress String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant        Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@map("user_restaurant_favorites")
}

model UserHotelFavorite {
  id                String   @id @default(cuid())
  userId            String
  hotelKey          String
  hotelName         String
  hotelImage        String
  hotelUrl          String
  hotelLocationSlug String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hotelKey])
  @@map("user_hotel_favorites")
}

model Restaurant {
  id               String                   @id @default(cuid())
  nom              String
  imageUrls        String // JSON array of URL strings
  adresse          String
  distinction      Int // 1, 2 or 3 (etoiles Michelin)
  latitude         Float?
  longitude        Float?
  ville            String?
  pays             String?
  cuisineType      String?
  priceRange       String?
  michelinSlug     String?                  @unique
  sourceUrl        String?
  sourceHotelName  String?
  sourceAttributes String                   @default("{}") // JSON object with extra scraped metadata
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  horaires         RestaurantHoraire[]
  dishes           Dish[]
  favoritedByUsers UserRestaurantFavorite[]

  @@map("restaurants")
}

model RestaurantHoraire {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  jour         String // LUNDI | MARDI | MERCREDI | JEUDI | VENDREDI | SAMEDI | DIMANCHE
  creneaux     String // JSON array: [{ouverture: "12:00", fermeture: "14:30"}, ...]

  @@unique([restaurantId, jour])
  @@map("restaurant_horaires")
}

model Dish {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  sourceKey    String     @unique // stable id used by the front favorites flow
  title        String
  caption      String
  imageUrl     String
  cuisine      String
  mood         String
  budget       String
  prepTime     Int
  vegan        Boolean    @default(false)
  ingredients  String     @default("[]") // JSON string[]
  allergens    String     @default("[]") // JSON string[]
  tags         String     @default("[]") // JSON string[]
  sourceUrl    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([restaurantId])
  @@index([cuisine])
  @@map("dishes")
}
